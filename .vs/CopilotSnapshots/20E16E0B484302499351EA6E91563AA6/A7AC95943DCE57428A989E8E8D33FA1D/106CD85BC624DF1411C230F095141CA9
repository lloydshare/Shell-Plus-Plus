    private static readonly BlockingCollection<Action> _mainThreadQueue = new();

    // Start a dispatcher loop on the main thread
    static Terminal()
    {
        Task.Run(() =>
        {
            foreach (var action in _mainThreadQueue.GetConsumingEnumerable())
            {
                action();
            }
        });
    }

    public static int WindowHeight
    {
        get
        {
            var getHeight = AppDomain.CurrentDomain.GetData("WindowHeight") as Func<int>;
            if (getHeight == null) return 0;

            // Avoid deadlock: do NOT block on Task.Result if already on main thread or if main thread is blocked
            if (Thread.CurrentThread.ManagedThreadId == 1)
                return getHeight();

            // Try to post to the main UI thread using SynchronizationContext if available
            var context = SynchronizationContext.Current;
            if (context != null)
            {
                int result = 0;
                Exception ex = null;
                context.Send(_ =>
                {
                    try { result = getHeight(); }
                    catch (Exception e) { ex = e; }
                }, null);
                if (ex != null) throw ex;
                return result;
            }

            // Fallback: use the queue, but warn this may hang if main thread is not pumping
            var tcs = new TaskCompletionSource<int>();
            _mainThreadQueue.Add(() =>
            {
                try { tcs.SetResult(getHeight()); }
                catch (Exception ex2) { tcs.SetException(ex2); }
            });
            return tcs.Task.Result;
        }
    }

    // Helper to invoke on main thread and get result
    public static T InvokeOnMainThread<T>(Func<T> func)
    {
        if (Thread.CurrentThread.ManagedThreadId == 1) // Already on main thread
            return func();

        var tcs = new TaskCompletionSource<T>();
        _mainThreadQueue.Add(() =>
        {
            try { tcs.SetResult(func()); }
            catch (Exception ex) { tcs.SetException(ex); }
        });
        return tcs.Task.Result;
    }

